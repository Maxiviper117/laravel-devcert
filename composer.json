{
    "name": "maxiviper117/laravel-devcert",
    "description": "Laravel local HTTPS setup with mkcert",
    "keywords": [
        "maxiviper117",
        "laravel",
        "https",
        "mkcert"
    ],
    "homepage": "https://github.com/Maxiviper117/laravel-devcert",
    "license": "MIT",
    "authors": [
        {
            "name": "Maxiviper117",
            "email": "11472492+Maxiviper117@users.noreply.github.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "larastan/larastan": "^3.0",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^11.0.0||^10.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "rector/rector": "^2.4",
        "spatie/laravel-ray": "^1.35"
    },
    "autoload": {
        "psr-4": {
            "Maxiviper117\\LaravelDevcert\\": "src/",
            "Maxiviper117\\LaravelDevcert\\Database\\Factories\\": "database/factories/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Maxiviper117\\LaravelDevcert\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "analyse": "@php build/phpstan/run.php",
        "rector": "vendor/bin/rector process",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Maxiviper117\\LaravelDevcert\\LaravelDevcertServiceProvider"
            ],
            "aliases": {
                "LaravelDevcert": "Maxiviper117\\LaravelDevcert\\Facades\\LaravelDevcert"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}